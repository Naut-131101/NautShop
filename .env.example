APP_NAME="Naut Shop"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/naut-shop

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=naut_shop
DB_USER=root
DB_PASS=

SESSION_NAME=naut_shop_session

JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=your_email@gmail.com
MAIL_FROM_NAME="Naut Shop"

OTP_TTL=300

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost/naut-shop/public/auth/google/callback

VIETQR_CLIENT_ID=
